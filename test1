<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Eye Glass Optics</title>
  <link rel="manifest" href="manifest.json" />
  <meta name="theme-color" content="#1a8fe3" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Eye Glass Optics" />
  <!-- <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" /> -->
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg:       #fff;
      --textfinalcolor: #000;
      /* 0a0f1e */
      --surf:     #0d1525;
      --surf2:    #111e33;
      --border:   #1a2f4a;
      --border2:  #1f3d62;
      --accent:   #1a8fe3;
      --accent-d: #1265a8;
      --violet:   #5bb8f5;
      --green:    #4ade80;
      --red:      #f87171;
      --amber:    #fbbf24;
      --wa:       #25D366;
      --text:     #e2eaf5;
      --muted:    #4d6480;
      --muted2:   #7a95b0;
      --head:     'Bebas Neue', sans-serif;
      --body:     'Poppins', sans-serif;
      --r:        14px;
      --r-lg:     20px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

    body { background: var(--bg); color: var(--accent); font-family: var(--body); font-size: 14px; min-height: 100vh; overflow-x: hidden; }

    ::-webkit-scrollbar { width: 3px; height: 3px; }
    ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

    /* ─── LOADER ─── */
    #loader {
      position: fixed; inset: 0; background: var(--bg); z-index: 9999;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      transition: opacity .4s;
    }
    .loader-eye {
      width: 56px; height: 56px; position: relative;
    }
    .loader-eye svg { animation: blink 1.8s ease-in-out infinite; }
    @keyframes blink {
      0%,100% { transform: scaleY(1); }
      45%,55% { transform: scaleY(0.1); }
    }
    #loader p { margin-top: 18px; font-family: var(--head); font-size: 11px; letter-spacing: 3px; color: var(--muted2); text-transform: uppercase; }

    /* ─── SETUP ─── */
    #setup {
      display: none; position: fixed; inset: 0; background: var(--bg);
      z-index: 999; overflow-y: auto; padding: 28px 16px 48px;
    }
    .setup-wrap { max-width: 460px; margin: 0 auto; }
    .setup-logo { font-family: var(--head); font-size: 28px; font-weight: 800; color: var(--accent); margin-bottom: 4px; }
    .setup-sub { font-size: 13px; color: var(--muted2); margin-bottom: 32px; }
    .step { display: none; }
    .step.on { display: block; animation: fadeUp .25s ease; }
    .step-label { font-size: 11px; font-weight: 600; color: var(--accent); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    .step-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    /* ─── APP SHELL ─── */
    #app { display: none; min-height: 100vh; }

    /* ─── TOPBAR ─── */
    .topbar {
      position: sticky; top: 0; z-index: 200;
      background: rgba(247, 247, 247, 0.97); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      padding: 0 16px; height: 56px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .topbar-left { display: flex; align-items: center; gap: 10px; }
    .t-logo { font-family: var(--head); font-size: 17px; font-weight: 800; color: var(--accent); }
    .branch-chip {
      background: var(--surf2); border: 1px solid var(--border2);
      border-radius: 20px; padding: 4px 12px; font-size: 11px; font-weight: 600;
      color: var(--violet); cursor: pointer; transition: all .18s; user-select: none;
      display: flex; align-items: center; gap: 5px;
    }
    .branch-chip:active { transform: scale(.96); }
    .branch-chip svg { width: 10px; height: 10px; fill: var(--violet); }
    .fb-pill {
      display: flex; align-items: center; gap: 5px;
      font-size: 11px; font-weight: 600; color: var(--muted2);
    }
    .fb-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse-dot 2.5s ease-in-out infinite; }
    .fb-dot.off { background: var(--red); animation: none; }
    @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* ─── BOTTOM NAV ─── */
    .bottom-nav {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
      background: rgba(247, 247, 247, 0.97); backdrop-filter: blur(16px);
      border-top: 1px solid var(--border);
      display: flex; padding: 8px 4px calc(8px + env(safe-area-inset-bottom));
    }
    .bnav-btn {
      flex: 1; display: flex; flex-direction: column; align-items: center;
      gap: 3px; padding: 6px 4px; border: none; background: transparent;
      color: var(--muted); font-family: var(--body); font-size: 10px; font-weight: 500;
      cursor: pointer; border-radius: 10px; transition: all .18s;
    }
    .bnav-btn .icon { font-size: 20px; line-height: 1; transition: transform .18s; }
    .bnav-btn.on { color: var(--accent); }
    .bnav-btn.on .icon { transform: scale(1.15); }
    .bnav-btn:active { transform: scale(.93); }

    /* ─── PAGES ─── */
    .page { display: none; padding: 16px 14px calc(80px + env(safe-area-inset-bottom)); max-width: 680px; margin: 0 auto; }
    .page.on { display: block; animation: fadeUp .22s ease; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(10px) } to { opacity:1; transform:translateY(0) } }

    /* ─── TYPOGRAPHY ─── */
    .page-title { font-family: var(--head); font-size: 22px; font-weight: 800; margin-bottom: 16px; }
    .section-title { font-family: var(--head); font-size: 14px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .section-title::before { content: ''; width: 3px; height: 14px; background: var(--accent); border-radius: 2px; }

    /* ─── CARDS ─── */
    .card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 18px 16px; margin-bottom: 12px; }
    .card-sm { background: var(--bg); border: 1px solid var(--border); border-radius: var(--r); padding: 14px; margin-bottom: 10px; }

    /* ─── FORM ─── */
    .fg { display: flex; flex-direction: column; gap: 5px; margin-bottom: 11px; }
    .fg label { font-size: 11px; font-weight: 600; color: var(--textfinalcolor); text-transform: uppercase; letter-spacing: .5px; }
    .fg input, .fg select, .fg textarea {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: var(--r); padding: 11px 13px; color: var(--accent);
      font-family: var(--body); font-size: 14px; outline: none;
      transition: border-color .18s; width: 100%;
    }
    .fg input:focus, .fg select:focus, .fg textarea:focus { border-color: var(--accent); }
    .fg select option { background: var(--surf2); }
    .fg textarea { resize: vertical; min-height: 68px; }
    .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }

    /* ─── RX TABLE ─── */
    .rx-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin-bottom: 12px; }
    .rx-tbl { width: 100%; border-collapse: collapse; min-width: 360px; }
    .rx-tbl th { font-size: 10px; font-weight: 700; color: var(--textfinalcolor); text-transform: uppercase; letter-spacing: .5px; padding: 6px 6px; text-align: center; background: var(--bg); }
    .rx-tbl th:first-child { border-radius: 8px 0 0 8px; text-align: left; padding-left: 10px; }
    .rx-tbl th:last-child { border-radius: 0 8px 8px 0; }
    .rx-tbl td { padding: 3px; }
    .rx-tbl td input {
      width: 100%; background: var(--bg); border: 1px solid var(--border);
      border-radius: 8px; padding: 8px 4px; color: var(--textfinalcolor);
      font-size: 13px; font-family: var(--body); outline: none; text-align: center;
      transition: border-color .15s;
    }
    .rx-tbl td input:focus { border-color: var(--accent); }
    .rx-tbl td:first-child input {
      font-weight: 700; color: var(--violet); background: transparent;
      border: none; text-align: left; padding-left: 10px; cursor: default;
    }

    /* ─── BUTTONS ─── */
    .btn {
      padding: 12px 18px; border-radius: var(--r); border: none;
      font-family: var(--body); font-size: 14px; font-weight: 600;
      cursor: pointer; transition: all .18s;
      display: inline-flex; align-items: center; justify-content: center; gap: 7px;
    }
    .btn:active { transform: scale(.96); }
    .btn-accent  { background: var(--accent); color: #080e1a; }
    .btn-accent:hover  { background: #67e8f9; }
    .btn-ghost   { background: var(--surf2); color: var(--text); border: 1px solid var(--border); }
    .btn-ghost:hover   { border-color: var(--border2); }
    .btn-green   { background: var(--green); color: #080e1a; }
    .btn-red     { background: rgba(248,113,113,.12); color: var(--red); border: 1px solid rgba(248,113,113,.2); }
    .btn-wa      { background: var(--wa); color: #fff; font-weight: 700; }
    .btn-wa:hover      { background: #1db954; }
    .btn-sm   { padding: 7px 13px; font-size: 12px; border-radius: 9px; }
    .btn-full { width: 100%; }

    /* ─── WA BILL MODAL ─── */
    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.75); backdrop-filter: blur(6px); z-index: 500; align-items: flex-end; justify-content: center; padding: 0; }
    .overlay.on { display: flex; animation: fadeIn .2s ease; }
    @keyframes fadeIn { from{opacity:0} to{opacity:1} }

    .sheet {
      background: var(--surf); border: 1px solid var(--border);
      border-radius: 24px 24px 0 0; padding: 24px 18px calc(24px + env(safe-area-inset-bottom));
      width: 100%; max-width: 500px; max-height: 88vh; overflow-y: auto;
      animation: slideUp .28s cubic-bezier(.32,.72,0,1);
    }
    @keyframes slideUp { from{transform:translateY(40px);opacity:0} to{transform:translateY(0);opacity:1} }

    .sheet-handle { width: 36px; height: 4px; background: var(--border2); border-radius: 2px; margin: 0 auto 20px; }
    .sheet-title { font-family: var(--head); font-size: 18px; font-weight: 800; margin-bottom: 16px; }

    /* WhatsApp message preview */
    .wa-preview {
      background: #0d1f0f; border: 1px solid #1a3d1d;
      border-radius: 14px; padding: 16px; margin-bottom: 16px;
      font-family: 'Courier New', monospace; font-size: 12.5px;
      color: #c8e6c9; line-height: 1.7; white-space: pre-wrap;
      word-break: break-word; max-height: 300px; overflow-y: auto;
    }
    .wa-preview::-webkit-scrollbar { width: 3px; }
    .wa-preview::-webkit-scrollbar-thumb { background: #1a3d1d; }

    /* ─── MODAL (centre) ─── */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.7); backdrop-filter: blur(5px); z-index: 500; align-items: center; justify-content: center; padding: 20px; }
    .modal-overlay.on { display: flex; animation: fadeIn .2s ease; }
    .modal { background: var(--surf); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 24px 20px; width: 100%; max-width: 480px; max-height: 90vh; overflow-y: auto; }
    .modal-title { font-family: var(--head); font-size: 18px; font-weight: 800; margin-bottom: 18px; }

    /* ─── BADGES ─── */
    .badge { display: inline-flex; align-items: center; padding: 3px 9px; border-radius: 20px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .3px; }
    .b-green  { background: rgba(74,222,128,.12); color: var(--green); }
    .b-red    { background: rgba(248,113,113,.12); color: var(--red); }
    .b-amber  { background: rgba(251,191,36,.12);  color: var(--amber); }
    .b-cyan   { background: rgba(34,211,238,.12);  color: var(--accent); }
    .b-violet { background: rgba(167,139,250,.12); color: var(--violet); }

    /* ─── KPI ─── */
    .kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
    .kpi { background: var(--bg); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 16px 14px; }
    .kpi.hi { border-color: var(--accent-d); }
    .kpi-lbl { font-size: 10px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 6px; }
    .kpi-val { font-family: var(--head); font-size: 28px; font-weight: 800; line-height: 1; }
    .kpi-val.c-accent { color: var(--accent); }
    .kpi-val.c-green  { color: var(--green); }
    .kpi-val.c-red    { color: var(--red); }
    .kpi-sub { font-size: 11px; color: var(--muted); margin-top: 4px; }

    /* ─── TABLE ─── */
    .tbl { width: 100%; border-collapse: collapse; }
    .tbl th { font-size: 10px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; padding: 9px 10px; text-align: left; border-bottom: 1px solid var(--border); }
    .tbl td { padding: 11px 10px; font-size: 13px; border-bottom: 1px solid rgba(28,45,71,.5); vertical-align: middle; }
    .tbl tr:last-child td { border-bottom: none; }
    .tbl tr:hover td { background: rgba(34,211,238,.03); }

    /* ─── SEARCH ─── */
    .search { background: var(--bg); border: 1px solid var(--border); border-radius: 50px; padding: 10px 16px; width: 100%; color: var(--textfinalcolor); font-family: var(--body); font-size: 14px; outline: none; margin-bottom: 14px; }
    .search:focus { border-color: var(--accent); }

    /* ─── ALERT ─── */
    .alert-red { background: rgba(248,113,113,.07); border: 1px solid rgba(248,113,113,.2); border-radius: var(--r); padding: 11px 14px; font-size: 13px; color: var(--red); display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .alert-cyan { background: rgba(34,211,238,.06); border: 1px solid rgba(34,211,238,.18); border-radius: var(--r); padding: 11px 14px; font-size: 13px; color: var(--accent); margin-bottom: 12px; line-height: 1.6; }

    /* ─── EMPTY STATE ─── */
    .empty { text-align: center; padding: 40px 20px; color: var(--muted); }
    .empty .e-icon { font-size: 40px; margin-bottom: 12px; opacity: .5; }
    .empty p { font-size: 13px; }

    /* ─── FOLLOW-UP CARD ─── */
    .fu-card { background: var(--surf); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 14px 15px; margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .fu-card .fc-name { font-weight: 700; font-size: 14px; }
    .fu-card .fc-sub { font-size: 11px; color: var(--muted2); margin-top: 2px; }

    /* ─── ITEM ROW ─── */
    .item-row { display: grid; grid-template-columns: 1fr 52px 72px 30px; gap: 7px; margin-bottom: 7px; align-items: center; }
    .item-row input {
      background: var(--bg); border: 1px solid var(--border); border-radius: 9px;
      padding: 9px 8px; color: var(--textfinalcolor); font-family: var(--body); font-size: 13px;
      outline: none; width: 100%; text-align: center; transition: border-color .15s;
    }
    .item-row input:first-child { text-align: left; padding-left: 11px; }
    .item-row input:focus { border-color: var(--accent); }
    .del-btn { background: rgba(248,113,113,.1); border: 1px solid rgba(248,113,113,.18); color: var(--red); border-radius: 8px; padding: 9px 6px; cursor: pointer; font-size: 13px; transition: all .15s; width: 100%; }
    .del-btn:active { transform: scale(.9); }

    /* ─── STOCK CARD ─── */
    .stock-card { background: var(--surf); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 15px; margin-bottom: 10px; }
    .stock-meta { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; margin-top: 12px; }
    .stock-cell { background: var(--surf2); border-radius: 9px; padding: 8px; text-align: center; }
    .stock-cell .sc-v { font-family: var(--head); font-size: 18px; font-weight: 800; }
    .stock-cell .sc-l { font-size: 10px; color: var(--muted); margin-top: 2px; }

    /* ─── SETTINGS ─── */
    .si { display: flex; justify-content: space-between; align-items: center; padding: 13px 0; border-bottom: 1px solid var(--border); }
    .si:last-child { border-bottom: none; }
    .si-lbl { font-size: 14px; font-weight: 600; }
    .si-sub { font-size: 11px; color: var(--muted2); margin-top: 2px; }

    /* ─── TOAST ─── */
    #toast-box { position: fixed; top: 68px; right: 12px; z-index: 9000; display: flex; flex-direction: column; gap: 7px; pointer-events: none; }
    .toast { background: var(--surf2); border: 1px solid var(--border2); border-radius: 12px; padding: 11px 16px; font-size: 13px; font-weight: 500; max-width: 280px; display: flex; align-items: center; gap: 8px; animation: toastIn .25s ease; pointer-events: all; }
    .toast.ok  { border-color: rgba(74,222,128,.4); color: var(--green); }
    .toast.err { border-color: rgba(248,113,113,.4); color: var(--red); }
    .toast.info{ border-color: rgba(34,211,238,.3); color: var(--accent); }
    @keyframes toastIn { from{opacity:0;transform:translateX(14px)} to{opacity:1;transform:translateX(0)} }

    @media (max-width: 400px) {
      .row2, .row3 { grid-template-columns: 1fr; }
      .kpi-val { font-size: 22px; }
    }
  </style>
</head>
<body>

<!-- ─── LOADER ─── -->
<div id="loader">
  <div class="loader-eye">
    <svg width="56" height="56" viewBox="0 0 56 56" fill="none">
      <ellipse cx="28" cy="28" rx="26" ry="18" stroke="#1a2f4a" stroke-width="2.5"/>
      <ellipse cx="28" cy="28" rx="26" ry="18" stroke="#1a8fe3" stroke-width="2" stroke-dasharray="48 80" stroke-dashoffset="0">
        <animateTransform attributeName="transform" type="rotate" from="0 28 28" to="360 28 28" dur="2s" repeatCount="indefinite"/>
      </ellipse>
      <circle cx="28" cy="28" r="10" fill="#162035"/>
      <circle cx="28" cy="28" r="7" fill="#1a8fe3" opacity=".9"/>
      <circle cx="31" cy="25" r="2.5" fill="white" opacity=".6"/>
    </svg>
  </div>
  <p>Eye Glass Optics</p>
</div>

<!-- ─── TOAST ─── -->
<div id="toast-box"></div>

<!-- ════════════════════════════════════ -->
<!-- SETUP SCREEN                         -->
<!-- ════════════════════════════════════ -->
<div id="setup">
  <div class="setup-wrap">
    <div class="setup-logo">👓 Eye Glass Optics</div>
    <div class="setup-sub">One-time setup — takes 3 minutes</div>

    <!-- Step 1 -->
    <div class="step on" id="step-1">
      <div class="step-label">Step 1 of 3 &nbsp;·&nbsp; Firebase Database</div>
      <div class="alert-cyan" style="margin-bottom:16px;">
        Firebase is a free Google service that stores your data safely in the cloud.
        Follow the <strong>SETUP_GUIDE.md</strong> file included in this project to get your 3 keys. It takes about 10 minutes.
      </div>
      <div class="fg">
        <label>Firebase API Key</label>
        <input type="text" id="cfg-apiKey" placeholder="AIzaSy…" autocomplete="off" />
      </div>
      <div class="fg">
        <label>Project ID</label>
        <input type="text" id="cfg-projectId" placeholder="my-opticare-shop" autocomplete="off" />
      </div>
      <div class="fg" style="margin-bottom:20px;">
        <label>App ID</label>
        <input type="text" id="cfg-appId" placeholder="1:123456:web:abc…" autocomplete="off" />
      </div>
      <button class="btn btn-accent btn-full" onclick="goStep(2)">Next →</button>
    </div>

    <!-- Step 2 -->
    <div class="step" id="step-2">
      <div class="step-label">Step 2 of 3 &nbsp;·&nbsp; Shop Details</div>
      <div class="fg">
        <label>Shop Name *</label>
        <input type="text" id="cfg-shopName" placeholder="Eye Glass Optics" />
      </div>
      <div class="row2">
        <div class="fg">
          <label>Branch 1 Name</label>
          <input type="text" id="cfg-b1" placeholder="Virar East" />
        </div>
        <div class="fg">
          <label>Branch 2 Name</label>
          <input type="text" id="cfg-b2" placeholder="Market" />
        </div>
      </div>
      <div class="fg">
        <label>Shop WhatsApp Number</label>
        <input type="tel" id="cfg-phone" placeholder="+91 917875074180" />
      </div>
      <div class="fg" style="margin-bottom:20px;">
        <label>Address (shown in bill message)</label>
        <textarea id="cfg-addr" placeholder="Shop No.4, Shree Sairaj Apt., Near Durga Medical, Jivdani Road, Virar (East) - 401305"></textarea>
      </div>
      <div style="display:flex;gap:8px;">
        <button class="btn btn-ghost" onclick="goStep(1)" style="flex:1;">← Back</button>
        <button class="btn btn-accent" onclick="goStep(3)" style="flex:2;">Next →</button>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="step" id="step-3">
      <div class="step-label">Step 3 of 3 &nbsp;·&nbsp; Done!</div>
      <div style="text-align:center;padding:24px 0 28px;">
        <div style="font-size:54px;margin-bottom:14px;">🎉</div>
        <div style="font-family:var(--head);font-size:20px;font-weight:800;margin-bottom:8px;">You're all set!</div>
        <div style="font-size:13px;color:var(--muted2);line-height:1.7;">
          Open this page in Chrome → tap the menu (⋮) → <strong style="color:var(--text)">Add to Home screen</strong><br/>
          It will work like a real app on your phone.
        </div>
      </div>
      <button class="btn btn-green btn-full" onclick="finishSetup()">Open Eye Glass Optics →</button>
    </div>
