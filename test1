<!-- FIREBASE + APP LOGIC                 -->
<!-- ════════════════════════════════════ -->
<script type="module">
import { initializeApp }         from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, addDoc, getDocs, doc,
         updateDoc, deleteDoc, query, where, serverTimestamp }
  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

// ── STATE ──────────────────────────────────────────────────────────────
let db   = null;
let CFG  = JSON.parse(localStorage.getItem('oc_cfg') || 'null');
let BR   = localStorage.getItem('oc_br') || 'b1';
let ITEMS = [{ desc:'', qty:1, rate:0 }];
let CUSTS=[], BILLS=[], STOCK=[];
let CUR_CUST_ID = null;
let LAST_BILL   = null;

// ── BOOT ───────────────────────────────────────────────────────────────
window.addEventListener('load', async () => {
  await sleep(1000);
  fade('loader');
  await sleep(450);
  document.getElementById('loader').style.display = 'none';
  CFG ? initFB() : showSetup();
});

function showSetup(){ document.getElementById('setup').style.display='block'; }

function initFB(){
  try {
    const app = initializeApp({
      apiKey:      CFG.apiKey,
      authDomain:  `${CFG.projectId}.firebaseapp.com`,
      projectId:   CFG.projectId,
      storageBucket:`${CFG.projectId}.appspot.com`,
      appId:       CFG.appId,
    });
    db = getFirestore(app);
    setFBStatus(true);
  } catch(e) {
    setFBStatus(false);
    toast('Firebase error — running offline', 'err');
  }
  launchApp();
}

function launchApp(){
  document.getElementById('app').style.display='block';
  document.getElementById('bDate').value = today();
  loadSettings();
  refreshAll();
  document.getElementById('dashDate').textContent =
    new Date().toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long'});
  renderItems();
}

// ── SETUP STEPS ────────────────────────────────────────────────────────
window.goStep = function(n){
  if(n===2){
    const k=v('cfg-apiKey'), p=v('cfg-projectId'), a=v('cfg-appId');
    if(!k||!p||!a){ toast('Fill all Firebase fields','err'); return; }
    localStorage.setItem('oc_fb_tmp', JSON.stringify({apiKey:k,projectId:p,appId:a}));
  }
  if(n===3){
    const sn=v('cfg-shopName');
    if(!sn){ toast('Enter shop name','err'); return; }
    const fb=JSON.parse(localStorage.getItem('oc_fb_tmp')||'{}');
    CFG={...fb, shopName:sn,
      b1: v('cfg-b1')||'Branch 1',
      b2: v('cfg-b2')||'Branch 2',
      phone: v('cfg-phone'),
      addr:  v('cfg-addr'),
    };
    localStorage.setItem('oc_cfg', JSON.stringify(CFG));
  }
  document.querySelectorAll('.step').forEach(s=>s.classList.remove('on'));
  document.getElementById(`step-${n}`).classList.add('on');
};
window.finishSetup = function(){
  document.getElementById('setup').style.display='none';
  document.getElementById('loader').style.display='flex';
  document.getElementById('loader').style.opacity='1';
  setTimeout(initFB, 700);
};

// ── HELPERS ────────────────────────────────────────────────────────────
const v    = id => document.getElementById(id)?.value?.trim()||'';
const $    = id => document.getElementById(id);
const sleep= ms => new Promise(r=>setTimeout(r,ms));
const today= () => new Date().toISOString().split('T')[0];
const fade = id => { const el=$(id); if(el) el.style.opacity='0'; };
const brLabel = () => BR==='b1' ? (CFG?.b1||'Branch 1') : (CFG?.b2||'Branch 2');

function setFBStatus(ok){
  $('fbDot').classList.toggle('off',!ok);
  $('fbLabel').textContent = ok ? 'Live' : 'Offline';
}

window.toast = function(msg, type='info'){
  const el=document.createElement('div');
  el.className=`toast ${type}`;
  el.innerHTML=`<span>${type==='ok'?'✓':type==='err'?'✗':'ℹ'}</span> ${msg}`;
  $('toast-box').appendChild(el);
  setTimeout(()=>el.remove(), 3400);
};

// ── NAVIGATION ─────────────────────────────────────────────────────────
window.nav = function(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.bnav-btn').forEach(b=>b.classList.remove('on'));
  $(`p-${id}`).classList.add('on');
  document.querySelector(`[data-p="${id}"]`).classList.add('on');
  if(id==='custs')  renderCusts();
  if(id==='stock')  renderStock();
  if(id==='fu')     renderFU();
  if(id==='dash')   renderDash();
  if(id==='set')    loadSettings();
};

// ── BRANCH ─────────────────────────────────────────────────────────────
window.flipBranch = function(){
  BR = BR==='b1' ? 'b2' : 'b1';
  localStorage.setItem('oc_br', BR);
  $('branchLabel').textContent = brLabel();
  refreshAll();
  toast(`Switched to ${brLabel()}`, 'info');
};

// ── FIRESTORE CRUD ──────────────────────────────────────────────────────
async function fbAdd(col, data){
  if(!db) return localAdd(col, data);
  try {
    const r = await addDoc(collection(db,col), {...data, branch:BR, ts:serverTimestamp()});
    return r.id;
  } catch(e){ toast('Save failed: '+e.message,'err'); return null; }
}
async function fbAll(col){
  if(!db) return localAll(col);
  try {
    const s = await getDocs(query(collection(db,col), where('branch','==',BR)));
    return s.docs.map(d=>({id:d.id,...d.data()}));
  } catch(e){ return localAll(col); }
}
async function fbPatch(col, id, data){
  if(!db){ localPatch(col,id,data); return; }
  try { await updateDoc(doc(db,col,id), data); }
  catch(e){ toast('Update failed','err'); }
}
async function fbDel(col, id){
  if(!db){ localDel(col,id); return; }
  try { await deleteDoc(doc(db,col,id)); }
  catch(e){ toast('Delete failed','err'); }
}

// ── LOCAL FALLBACK ──────────────────────────────────────────────────────
function lKey(col){ return `oc_local_${col}`; }
function localAll(col){ return (JSON.parse(localStorage.getItem(lKey(col))||'[]')).filter(x=>x.branch===BR); }
function localAdd(col,data){
  const all=JSON.parse(localStorage.getItem(lKey(col))||'[]');
  const item={id:Date.now().toString(),...data,branch:BR,ts:new Date().toISOString()};
  all.push(item); localStorage.setItem(lKey(col),JSON.stringify(all)); return item.id;
}
function localPatch(col,id,data){
  const all=JSON.parse(localStorage.getItem(lKey(col))||'[]');
  const i=all.findIndex(x=>x.id===id); if(i>-1){all[i]={...all[i],...data}; localStorage.setItem(lKey(col),JSON.stringify(all));}
}
function localDel(col,id){
  const all=JSON.parse(localStorage.getItem(lKey(col))||'[]').filter(x=>x.id!==id);
  localStorage.setItem(lKey(col),JSON.stringify(all));
}

// ── REFRESH ─────────────────────────────────────────────────────────────
async function refreshAll(){
  [CUSTS, BILLS, STOCK] = await Promise.all([fbAll('customers'),fbAll('bills'),fbAll('stock')]);
  renderDash();
}

// ── DASHBOARD ────────────────────────────────────────────────────────────
function renderDash(){
  const td = today();
  const tb = BILLS.filter(b=>(b.date||'').startsWith(td));
  const rev= tb.reduce((s,b)=>s+Number(b.total||0),0);
  const low= STOCK.filter(s=>Number(s.qty)<=Number(s.minQty||5));

  $('k-bills').textContent = tb.length;
  $('k-rev').textContent   = '₹'+rev.toLocaleString('en-IN');
  $('k-custs').textContent = CUSTS.length;
  $('k-low').textContent   = low.length;

  $('stockAlerts').innerHTML = low.map(s=>
    `<div class="alert-red">⚠️ <strong>${s.name}</strong> — only ${s.qty} ${s.unit||'units'} left</div>`
  ).join('');

  const rec = [...BILLS].sort((a,b)=>new Date(b.ts||0)-new Date(a.ts||0)).slice(0,6);
  $('recentBills').innerHTML = rec.length===0
    ? `<div class="empty"><div class="e-icon">🧾</div><p>No bills yet today</p></div>`
    : `<table class="tbl"><thead><tr><th>Customer</th><th>Total</th><th>Mode</th><th></th></tr></thead><tbody>
      ${rec.map(b=>`<tr>
        <td><div style="font-weight:600;font-size:13px;">${b.custName}</div><div style="font-size:10px;color:var(--muted2)">${b.billNo||''}</div></td>
        <td style="color:var(--green);font-weight:700;">₹${Number(b.total).toLocaleString('en-IN')}</td>
        <td><span class="badge b-cyan">${b.payMode||'Cash'}</span></td>
        <td><button class="btn btn-ghost btn-sm" onclick="viewBill('${b.id}')">💬</button></td>
      </tr>`).join('')}
      </tbody></table>`;
}

// ── NEW BILL ──────────────────────────────────────────────────────────────
window.addItem = function(){
  ITEMS.push({desc:'',qty:1,rate:0}); renderItems();
};
function renderItems(){
  $('itemsBox').innerHTML = ITEMS.map((it,i)=>`
    <div class="item-row">
      <input type="text"   placeholder="Item description" value="${it.desc}" onchange="upItem(${i},'desc',this.value)" />
      <input type="number" placeholder="Qty" value="${it.qty}" min="1" onchange="upItem(${i},'qty',+this.value)" />
      <input type="number" placeholder="₹" value="${it.rate||''}" onchange="upItem(${i},'rate',+this.value)" />
      <button class="del-btn" onclick="delItem(${i})">✕</button>
    </div>`).join('');
  calcTot();
}
window.upItem = function(i,f,v){ ITEMS[i][f]=v; calcTot(); };
window.delItem= function(i){ if(ITEMS.length>1){ITEMS.splice(i,1);renderItems();} };
window.calcTot= function(){
  const sub = ITEMS.reduce((s,it)=>s+(it.qty*it.rate),0);
  const disc= Number($('bDisc')?.value||0);
  if($('bSub'))  $('bSub').value  = sub;
  if($('bTotal'))$('bTotal').value = sub-disc;
};

window.clearBill = function(){
  ['bName','bPhone','bAge','bDoctor','bNotes'].forEach(id=>{if($(id))$(id).value='';});
  ['rRsph','rRcyl','rRaxis','rRadd','rRva','rLsph','rLcyl','rLaxis','rLadd','rLva']
    .forEach(id=>{if($(id))$(id).value='';});
  if($('bDisc'))$('bDisc').value=0;
  if($('bDate'))$('bDate').value=today();
  ITEMS=[{desc:'',qty:1,rate:0}]; CUR_CUST_ID=null;
  renderItems(); toast('Form cleared','info');
};

function buildBillObj(){
  const name=v('bName'), phone=v('bPhone');
  if(!name){ toast('Enter customer name','err'); return null; }
  if(!phone||phone.length<10){ toast('Enter valid 10-digit phone','err'); return null; }
  const filled=ITEMS.filter(it=>it.desc.trim()&&it.rate>0);
  if(!filled.length){ toast('Add at least one item with price','err'); return null; }
  return {
    custName:name, phone, age:v('bAge'), date:v('bDate'), doctor:v('bDoctor'),
    rx:{ R:{sph:v('rRsph'),cyl:v('rRcyl'),axis:v('rRaxis'),add:v('rRadd'),va:v('rRva')},
         L:{sph:v('rLsph'),cyl:v('rLcyl'),axis:v('rLaxis'),add:v('rLadd'),va:v('rLva')} },
    items:filled,
    subtotal:Number($('bSub')?.value||0),
    discount:Number($('bDisc')?.value||0),
    total:   Number($('bTotal')?.value||0),
    payMode: $('bPay')?.value||'Cash',
    notes:   v('bNotes'),
  };
}

window.saveBill = async function(){
  const data=buildBillObj(); if(!data)return;

  // upsert customer
  let cid=CUR_CUST_ID;
  const ex=CUSTS.find(c=>c.phone===data.phone);
  if(ex){
    cid=ex.id;
    await fbPatch('customers',cid,{name:data.custName,lastVisit:data.date,rx:data.rx,doctor:data.doctor});
  } else {
    cid=await fbAdd('customers',{name:data.custName,phone:data.phone,age:data.age,
      firstVisit:data.date,lastVisit:data.date,rx:data.rx,doctor:data.doctor});
  }

  const num=BILLS.length+1;
  const billNo=`${BR.toUpperCase()}-${new Date().getFullYear()}-${String(num).padStart(4,'0')}`;
  const bid=await fbAdd('bills',{...data,billNo,custId:cid});

  if(bid){
    toast('Bill saved!','ok');
    LAST_BILL={...data,billNo,id:bid};
    await refreshAll();
    openWASheet(LAST_BILL);
  }
};

// ── WHATSAPP BILL ──────────────────────────────────────────────────────
function buildWAMsg(b){
  const c=CFG||{};
  const items=b.items.map(it=>`  • ${it.desc} ×${it.qty} = ₹${(it.qty*it.rate).toLocaleString('en-IN')}`).join('\n');
  const rx=b.rx;
  const hasRx=rx&&(rx.R?.sph||rx.R?.cyl||rx.L?.sph||rx.L?.cyl);
  const rxBlock=hasRx ? `\n👁️ *Prescription (Rx):*\n` +
    `  Right → SPH:${rx.R?.sph||'—'} CYL:${rx.R?.cyl||'—'} AXIS:${rx.R?.axis||'—'} ADD:${rx.R?.add||'—'}\n`+
    `  Left  → SPH:${rx.L?.sph||'—'} CYL:${rx.L?.cyl||'—'} AXIS:${rx.L?.axis||'—'} ADD:${rx.L?.add||'—'}\n` : '';
  return `👓 *${c.shopName||'👓 Eye Glass Optics'}* | ${brLabel()}
━━━━━━━━━━━━━━━━━━━━
📋 *Bill No:* ${b.billNo}
📅 *Date:* ${b.date}
👤 *Name:* ${b.custName}
${b.doctor ? `💊 *Dr:* ${b.doctor}\n` : ''}${rxBlock}
🛍️ *Items:*
${items}
━━━━━━━━━━━━━━━━━━━━
${b.discount>0?`💸 Discount: -₹${b.discount}\n`:''}💰 *Total: ₹${Number(b.total).toLocaleString('en-IN')}*
💳 Payment: ${b.payMode}
${b.notes?`📝 ${b.notes}\n`:''}
Thank you for visiting! 🙏
Please come for your annual checkup next year.
📞 ${c.phone||''} | ${c.addr||''}`;
}

function openWASheet(b){
  $('waPreviewText').textContent = buildWAMsg(b);
  $('waPhone').value = b.phone||'';
  $('waSheet').classList.add('on');
}

window.waPreviewOnly = function(){
  const data=buildBillObj(); if(!data)return;
  LAST_BILL={...data,billNo:'PREVIEW'};
  openWASheet(LAST_BILL);
};

window.sendWA = function(){
  if(!LAST_BILL)return;
  const ph=($('waPhone').value||'').replace(/\D/g,'');
  const full=ph.length===10?'91'+ph:ph;
  if(full.length<12){ toast('Enter valid phone number','err'); return; }
  const msg=buildWAMsg(LAST_BILL);
  window.open(`https://wa.me/${full}?text=${encodeURIComponent(msg)}`, '_blank');
};

window.viewBill = function(id){
  const b=BILLS.find(x=>x.id===id); if(!b)return;
  LAST_BILL=b; openWASheet(b);
};

window.closeSheet = function(){ $('waSheet').classList.remove('on'); };

// ── CUSTOMERS ──────────────────────────────────────────────────────────
window.renderCusts = function(){
  const q=($('custSearch')?.value||'').toLowerCase();
  const f=CUSTS.filter(c=>c.name?.toLowerCase().includes(q)||c.phone?.includes(q))
    .sort((a,b)=>(b.lastVisit||'')>(a.lastVisit||'')?1:-1);
  $('custCount').textContent=`${f.length} customers`;
  $('custList').innerHTML = f.length===0
    ? `<div class="empty"><div class="e-icon">👤</div><p>No customers found</p></div>`
    : f.map(c=>`
      <div class="card-sm" onclick="openCustModal('${c.id}')" style="cursor:pointer;">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <div>
            <div style="font-weight:700;font-size:14px;">${c.name}</div>
            <div style="font-size:11px;color:var(--textfinalcolor);margin-top:3px;">📞 ${c.phone}${c.age?' · Age '+c.age:''}</div>
            <div style="font-size:10px;color:var(--textfinalcolor);margin-top:2px;">Last: ${c.lastVisit||'—'}</div>
          </div>
          <div style="color:var(--muted2);font-size:20px;">›</div>
        </div>
      </div>`).join('');
};

window.openCustModal = function(id){
  const c=CUSTS.find(x=>x.id===id); if(!c)return;
  CUR_CUST_ID=id;
  const rx=c.rx||{};
  const cb=BILLS.filter(b=>b.custId===id||b.phone===c.phone);
  $('custModalTitle').textContent=c.name;
  const rxRow=(eye,d)=>d?`<tr><td>${eye}</td><td>${d.sph||'—'}</td><td>${d.cyl||'—'}</td><td>${d.axis||'—'}</td><td>${d.add||'—'}</td></tr>`:'';
  $('custModalBody').innerHTML=`
    <div style="font-size:13px;line-height:2.1;color:var(--muted2);">
      📞 <strong style="color:var(--text)">${c.phone}</strong><br/>
      ${c.age?`🎂 Age: <strong style="color:var(--text)">${c.age}</strong><br/>`:''}
      📅 First visit: <strong style="color:var(--text)">${c.firstVisit||'—'}</strong><br/>
      📅 Last visit: <strong style="color:var(--text)">${c.lastVisit||'—'}</strong>
      ${c.doctor?`<br/>💊 Dr: <strong style="color:var(--text)">${c.doctor}</strong>`:''}
    </div>
    ${(rx.R||rx.L)?`
    <div style="margin-top:12px;padding:12px;background:var(--surf2);border-radius:10px;">
      <div style="font-size:10px;font-weight:700;color:var(--muted);margin-bottom:8px;text-transform:uppercase;">Last Prescription</div>
      <table style="width:100%;font-size:12px;border-collapse:collapse;">
        <thead><tr style="color:var(--muted2)"><th style="padding:3px 4px;text-align:left">Eye</th><th>SPH</th><th>CYL</th><th>AXIS</th><th>ADD</th></tr></thead>
        <tbody>${rxRow('Right',rx.R)}${rxRow('Left',rx.L)}</tbody>
      </table>
    </div>` : ''}
    <div style="margin-top:12px;font-size:12px;color:var(--muted2);">
      Total bills: <strong style="color:var(--text)">${cb.length}</strong> · 
      Total spent: <strong style="color:var(--green)">₹${cb.reduce((s,b)=>s+Number(b.total||0),0).toLocaleString('en-IN')}</strong>
    </div>`;
  $('custModal').classList.add('on');
};

window.waCust = function(){
  const c=CUSTS.find(x=>x.id===CUR_CUST_ID); if(!c)return;
  const ph=(c.phone||'').replace(/\D/g,'');
  const full=ph.length===10?'91'+ph:ph;
  window.open(`https://wa.me/${full}`,'_blank');
  closeModal();
};

window.rebill = function(){
  const c=CUSTS.find(x=>x.id===CUR_CUST_ID); if(!c)return;
  closeModal();
  clearBill();
  if($('bName'))$('bName').value=c.name;
  if($('bPhone'))$('bPhone').value=c.phone;
  if($('bAge'))$('bAge').value=c.age||'';
  if(c.rx){
    ['sph','cyl','axis','add','va'].forEach(f=>{
      if($(`rR${f}`))$(`rR${f}`).value=c.rx.R?.[f]||'';
      if($(`rL${f}`))$(`rL${f}`).value=c.rx.L?.[f]||'';
    });
  }
  CUR_CUST_ID=c.id;
  nav('bill');
  toast(`Loaded ${c.name}`, 'ok');
};

window.autofillCust = function(val){
  if(val.length<2)return;
  const m=CUSTS.find(c=>c.name.toLowerCase().startsWith(val.toLowerCase()));
  if(m){
    if($('bPhone'))$('bPhone').value=m.phone;
    if($('bAge'))$('bAge').value=m.age||'';
    if(m.rx){
      ['sph','cyl','axis','add','va'].forEach(f=>{
        if($(`rR${f}`))$(`rR${f}`).value=m.rx.R?.[f]||'';
        if($(`rL${f}`))$(`rL${f}`).value=m.rx.L?.[f]||'';
      });
    }
    CUR_CUST_ID=m.id;
  }
};

// ── STOCK ──────────────────────────────────────────────────────────────
function renderStock(){
  $('stockList').innerHTML = STOCK.length===0
    ? `<div class="empty"><div class="e-icon">📦</div><p>No stock items yet</p></div>`
    : STOCK.map(s=>{
      const low=Number(s.qty)<=Number(s.minQty||5);
      return `<div class="stock-card">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;">
          <div>
            <div style="font-weight:700;font-size:14px;">${s.name}</div>
            <div style="font-size:11px;color:var(--muted2);margin-top:2px;">${s.cat||'—'}</div>
          </div>
          <span class="badge ${low?'b-red':'b-green'}">${low?'Low Stock':'OK'}</span>
        </div>
        <div class="stock-meta">
          <div class="stock-cell">
            <div class="sc-v" style="color:${low?'var(--red)':'var(--text)'}">${s.qty}</div>
            <div class="sc-l">In Stock (${s.unit||'units'})</div>
          </div>
          <div class="stock-cell">
            <div class="sc-v" style="font-size:15px;">₹${s.costPrice||0}</div>
            <div class="sc-l">Cost</div>
          </div>
          <div class="stock-cell">
            <div class="sc-v" style="color:var(--green);font-size:15px;">₹${s.sellPrice||0}</div>
            <div class="sc-l">Sell</div>
          </div>
        </div>
        <div style="display:flex;gap:8px;margin-top:12px;">
          <button class="btn btn-ghost btn-sm" onclick="adjStock('${s.id}',${s.qty},'${s.unit||'units'}')">Adjust</button>
          <button class="btn btn-red btn-sm" onclick="delStock('${s.id}')">Remove</button>
        </div>
      </div>`;
    }).join('');
}

window.openStockModal = function(){
  ['stName','stQty','stMin','stCost','stSell'].forEach(id=>{if($(id))$(id).value='';});
  $('stockModal').classList.add('on');
};
window.saveStock = async function(){
  const nm=v('stName'); if(!nm){toast('Enter item name','err');return;}
  await fbAdd('stock',{name:nm,cat:v('stCat'),unit:v('stUnit'),
    qty:+v('stQty')||0, minQty:+v('stMin')||5,
    costPrice:+v('stCost')||0, sellPrice:+v('stSell')||0});
  closeModal(); STOCK=await fbAll('stock'); renderStock(); toast('Item added!','ok');
};
window.adjStock = async function(id,cur,unit){
  const nq=prompt(`Current: ${cur} ${unit}\nEnter new quantity:`);
  if(nq===null||isNaN(nq))return;
  await fbPatch('stock',id,{qty:+nq});
  STOCK=await fbAll('stock'); renderStock(); renderDash(); toast('Stock updated','ok');
};
window.delStock = async function(id){
  if(!confirm('Remove this item?'))return;
  await fbDel('stock',id);
  STOCK=await fbAll('stock'); renderStock(); toast('Removed','info');
};

// ── FOLLOW-UP ──────────────────────────────────────────────────────────
function renderFU(){
  const now=new Date();
  const due=BILLS.filter(b=>{
    if(!b.date)return false;
    const m=(now-new Date(b.date))/(1000*60*60*24*30);
    return m>=11&&m<=14;
  });
  const c=CFG||{};
  $('fuList').innerHTML = due.length===0
    ? `<div class="empty"><div class="e-icon">🎉</div><p>No follow-ups due right now.<br/>Check back next month.</p></div>`
    : due.map(b=>{
      const ph=(b.phone||'').replace(/\D/g,'');
      const full=ph.length===10?'91'+ph:ph;
      const msg=`Hello ${b.custName} 😊\n\nIt's been almost a year since your last eye checkup at *${c.shopName||'our shop'}*.\n\nWe recommend an annual eye exam to make sure your prescription is still correct.\n\n📅 Call us to book an appointment!\n📞 ${c.phone||''} | ${brLabel()}`;
      return `<div class="fu-card">
        <div>
          <div class="fc-name">${b.custName}</div>
          <div class="fc-sub">📞 ${b.phone} · Last visit: ${b.date}</div>
        </div>
        <a href="https://wa.me/${full}?text=${encodeURIComponent(msg)}" target="_blank">
          <button class="btn btn-wa btn-sm">Remind 💬</button>
        </a>
      </div>`;
    }).join('');
}

// ── SETTINGS ────────────────────────────────────────────────────────────
function loadSettings(){
  const c=CFG||{};
  if($('sName')) $('sName').value=c.shopName||'';
  if($('sB1'))   $('sB1').value  =c.b1||'';
  if($('sB2'))   $('sB2').value  =c.b2||'';
  if($('sPhone'))$('sPhone').value=c.phone||'';
  if($('sAddr')) $('sAddr').value =c.addr||'';
  if($('branchLabel'))$('branchLabel').textContent=brLabel();
}
window.saveSettings = function(){
  CFG={...CFG,shopName:v('sName'),b1:v('sB1'),b2:v('sB2'),phone:v('sPhone'),addr:v('sAddr')};
  localStorage.setItem('oc_cfg',JSON.stringify(CFG));
  if($('branchLabel'))$('branchLabel').textContent=brLabel();
  toast('Settings saved!','ok');
};

// ── EXPORT / IMPORT ─────────────────────────────────────────────────────
window.exportData = function(){
  const data={customers:CUSTS,bills:BILLS,stock:STOCK,cfg:CFG,at:new Date().toISOString()};
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(data,null,2)],{type:'application/json'}));
  a.download=`opticare-backup-${today()}.json`; a.click();
  toast('Backup downloaded!','ok');
};
window.importData = function(e){
  const f=e.target.files[0]; if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{
    try{
      const d=JSON.parse(ev.target.result);
      if(d.cfg){CFG=d.cfg;localStorage.setItem('oc_cfg',JSON.stringify(CFG));}
      toast('Restored! Reload the page.','ok');
    }catch{toast('Invalid file','err');}
  };
  r.readAsText(f);
};
window.backupWA = function(){
  const c=CFG||{};
  const msg=`📦 *Eye Glass Optics Backup*\n🏥 ${c.shopName||'Shop'}\n📅 ${new Date().toLocaleDateString('en-IN')}\n\n👥 Customers: ${CUSTS.length}\n🧾 Bills: ${BILLS.length}\n📦 Stock: ${STOCK.length} items\n\n_Please also export the full JSON backup from Settings._`;
  window.open(`https://wa.me/?text=${encodeURIComponent(msg)}`,'_blank');
};

// ── MODAL HELPERS ────────────────────────────────────────────────────────
window.closeModal = function(){
  document.querySelectorAll('.modal-overlay').forEach(m=>m.classList.remove('on'));
};
// Close overlays on backdrop tap
document.querySelectorAll('.overlay,.modal-overlay').forEach(el=>{
  el.addEventListener('click', e=>{ if(e.target===el){ el.classList.remove('on'); } });
});

</script>
